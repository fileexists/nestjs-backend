{
  "name": "nestjs-backend",
  "description": "Authentication backend built with NestJS, JWT, role and permission system, refresh token rotation, and OAuth2 (Google).",
  "author": "Deyvid Manolov - fileexists",
  "version": "1.0.0",
  "license": "MIT",
  "private": false,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "npx ts-node database/seeds/init.ts",
    "migration:generate": "npx typeorm-ts-node-commonjs migration:generate -d typeorm.config.ts",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d typeorm.config.ts",
    "migration:revert": "npx typeorm-ts-node-commonjs migration:revert -d typeorm.config.ts",
    "migration:show": "npx typeorm-ts-node-commonjs migration:show -d typeorm.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.0.5",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "joi": "^18.2.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.30"
  },
  "resolutions": {
    "@babel/core": "^7.29.6",
    "handlebars": "^4.7.9",
    "piscina": "^4.9.3",
    "@xhmikosr/decompress": "^10.2.1",
    "file-type": "^21.3.4",
    "yauzl": "^3.2.1",
    "fast-uri": "^3.1.2",
    "serialize-javascript": "^7.0.5",
    "flatted": "^3.4.2",
    "form-data": "^4.0.6",
    "**/@angular-devkit/core/ajv": "^8.18.0",
    "**/@angular-devkit/core/picomatch": "^4.0.4",
    "**/tinyglobby/picomatch": "^4.0.4",
    "**/jest-util/picomatch": "^2.3.2",
    "**/micromatch/picomatch": "^2.3.2",
    "**/anymatch/picomatch": "^2.3.2",
    "**/@eslint/eslintrc/js-yaml": "^4.2.0",
    "**/cosmiconfig/js-yaml": "^4.2.0",
    "**/@istanbuljs/load-nyc-config/js-yaml": "^3.15.0",
    "**/node-emoji/lodash": "^4.18.0",
    "eslint/**/brace-expansion": "^1.1.13",
    "@eslint/eslintrc/**/brace-expansion": "^1.1.13",
    "jest/**/brace-expansion": "^1.1.13",
    "@nestjs/cli/**/brace-expansion": "^5.0.6",
    "@nestjs/cli/**/fork-ts-checker-webpack-plugin/**/brace-expansion": "^1.1.13",
    "@typescript-eslint/**/brace-expansion": "^5.0.6",
    "@swc/cli/**/brace-expansion": "^2.0.3",
    "typeorm/**/brace-expansion": "^2.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/../test-setup.ts"
    ]
  }
}
