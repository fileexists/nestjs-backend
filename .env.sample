PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-long-random-string
REFRESH_TOKEN_SECRET=change-me-to-another-long-random-string
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# PostgreSQL — docker-compose defaults shown below
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://nestjs:nestjs_secret@localhost:5432/nestjs_db

# Optional: used by docker-compose to override postgres defaults
POSTGRES_USER=nestjs
POSTGRES_PASSWORD=nestjs_secret
POSTGRES_DB=nestjs_db
POSTGRES_PORT=5432

# CORS — comma-separated list of allowed origins, or * for all
CORS_ORIGIN=http://localhost:3000

# Google OAuth2 — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
